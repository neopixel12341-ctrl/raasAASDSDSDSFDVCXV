-- Ultimate Persistent SkidFling + Smart Exclusions (FULL, SESSION ONLY)

-- ===== Services / locals =====
local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterGui = game:GetService("StarterGui")
local UserInputService = game:GetService("UserInputService")

-- ===== Globals & config =====
getgenv().Exclusions = getgenv().Exclusions or {} -- session only
getgenv().Welcome = getgenv().Welcome or false
getgenv().FPDH = getgenv().FPDH or workspace.FallenPartsDestroyHeight
getgenv().FlingEnabled = getgenv().FlingEnabled or true
getgenv().AllBool = getgenv().AllBool or false

local FLING_INTERVAL = 3.5

local ActiveFlingTargets = {}

-- ===== Utility =====
local function Notify(title, text, dur)
    pcall(function()
        StarterGui:SetCore("SendNotification", {Title = title, Text = text, Duration = dur or 3})
    end)
end

local function findPlayersByPartial(partial)
    partial = tostring(partial or ""):lower()
    local matches = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Player then
            local uname = (p.Name or ""):lower()
            local dname = (p.DisplayName or ""):lower()
            if uname:sub(1, #partial) == partial or dname:sub(1, #partial) == partial then
                table.insert(matches, p)
            end
        end
    end
    return matches
end

-- ===== FULL SkidFling (UNCHANGED) =====
local function SkidFling(TargetPlayer)
    -- The following function is intended to be as close as reasonably possible to your original
    -- SkidFling behavior while adding pcall safety around dangerous ops so it doesn't break loops.
    local success, err = pcall(function()
        local Character = Player.Character
        local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
        local RootPart = Humanoid and Humanoid.RootPart

        if not TargetPlayer or not TargetPlayer.Character then
            return
        end

        local TCharacter = TargetPlayer.Character
        local THumanoid
        local TRootPart
        local THead
        local Accessory
        local Handle

        if TCharacter:FindFirstChildOfClass("Humanoid") then
            THumanoid = TCharacter:FindFirstChildOfClass("Humanoid")
        end
        if THumanoid and THumanoid.RootPart then
            TRootPart = THumanoid.RootPart
        end
        if TCharacter:FindFirstChild("Head") then
            THead = TCharacter.Head
        end
        -- pick first accessory if present
        if TCharacter:FindFirstChildOfClass("Accessory") then
            Accessory = TCharacter:FindFirstChildOfClass("Accessory")
        end
        if Accessory and Accessory:FindFirstChild("Handle") then
            Handle = Accessory.Handle
        end

        if Character and Humanoid and RootPart then
            if RootPart.Velocity.Magnitude < 50 then
                getgenv().OldPos = RootPart.CFrame
            end
            if THumanoid and THumanoid.Sit and not getgenv().AllBool then
                return Notify("Error Occurred", "Targeting is sitting", 5)
            end

            if THead then
                workspace.CurrentCamera.CameraSubject = THead
            elseif not THead and Handle then
                workspace.CurrentCamera.CameraSubject = Handle
            elseif THumanoid and TRootPart then
                workspace.CurrentCamera.CameraSubject = THumanoid
            end

            if not TCharacter:FindFirstChildWhichIsA("BasePart") then
                return
            end

            local FPos = function(BasePart, Pos, Ang)
                if not RootPart or not Character or not Character.PrimaryPart then return end
                RootPart.CFrame = CFrame.new(BasePart.Position) * Pos * Ang
                pcall(function() Character:SetPrimaryPartCFrame(CFrame.new(BasePart.Position) * Pos * Ang) end)
                if RootPart then
                    RootPart.Velocity = Vector3.new(9e7, 9e7 * 10, 9e7)
                    RootPart.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
                end
            end

            local SFBasePart = function(BasePart)
                local TimeToWait = 2
                local Time = tick()
                local Angle = 0

                repeat
                    if RootPart and THumanoid then
                        if BasePart.Velocity.Magnitude < 50 then
                            Angle = Angle + 100

                            FPos(BasePart, CFrame.new(0, 1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                            task.wait()

                            FPos(BasePart, CFrame.new(0, -1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                            task.wait()

                            FPos(BasePart, CFrame.new(2.25, 1.5, -2.25) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                            task.wait()

                            FPos(BasePart, CFrame.new(-2.25, -1.5, 2.25) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                            task.wait()

                            FPos(BasePart, CFrame.new(0, 1.5, 0) + THumanoid.MoveDirection, CFrame.Angles(math.rad(Angle), 0, 0))
                            task.wait()

                            FPos(BasePart, CFrame.new(0, -1.5, 0) + THumanoid.MoveDirection, CFrame.Angles(math.rad(Angle), 0, 0))
                            task.wait()
                        else
                            FPos(BasePart, CFrame.new(0, 1.5, THumanoid.WalkSpeed), CFrame.Angles(math.rad(90), 0, 0))
                            task.wait()

                            FPos(BasePart, CFrame.new(0, -1.5, -THumanoid.WalkSpeed), CFrame.Angles(0, 0, 0))
                            task.wait()

                            FPos(BasePart, CFrame.new(0, 1.5, THumanoid.WalkSpeed), CFrame.Angles(math.rad(90), 0, 0))
                            task.wait()

                            FPos(BasePart, CFrame.new(0, 1.5, TRootPart.Velocity.Magnitude / 1.25), CFrame.Angles(math.rad(90), 0, 0))
                            task.wait()

                            FPos(BasePart, CFrame.new(0, -1.5, -TRootPart.Velocity.Magnitude / 1.25), CFrame.Angles(0, 0, 0))
                            task.wait()

                            FPos(BasePart, CFrame.new(0, 1.5, TRootPart.Velocity.Magnitude / 1.25), CFrame.Angles(math.rad(90), 0, 0))
                            task.wait()

                            FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(math.rad(90), 0, 0))
                            task.wait()

                            FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0))
                            task.wait()

                            FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(math.rad(-90), 0, 0))
                            task.wait()

                            FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0))
                            task.wait()
                        end
                    else
                        break
                    end
                until BasePart.Velocity.Magnitude > 500
                      or not BasePart.Parent
                      or (TargetPlayer.Parent ~= Players)
                      or (TargetPlayer.Character ~= TCharacter)
                      or (THumanoid and THumanoid.Sit)
                      or (Humanoid and Humanoid.Health <= 0)
                      or tick() > Time + TimeToWait
            end

            workspace.FallenPartsDestroyHeight = 0/0

            local BV = Instance.new("BodyVelocity")
            BV.Name = "EpixVel"
            BV.Parent = RootPart
            BV.Velocity = Vector3.new(9e8, 9e8, 9e8)
            BV.MaxForce = Vector3.new(1/0, 1/0, 1/0)

            Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)

            if TRootPart and THead then
                if (TRootPart.CFrame.p - THead.CFrame.p).Magnitude > 5 then
                    SFBasePart(THead)
                else
                    SFBasePart(TRootPart)
                end
            elseif TRootPart and not THead then
                SFBasePart(TRootPart)
            elseif not TRootPart and THead then
                SFBasePart(THead)
            elseif not TRootPart and not THead and Accessory and Handle then
                SFBasePart(Handle)
            else
                return Notify("Error Occurred", "Target is missing everything", 5)
            end

            if BV and BV.Parent then BV:Destroy() end
            Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
            workspace.CurrentCamera.CameraSubject = Humanoid

            repeat
                if not getgenv().OldPos then break end
                if RootPart and getgenv().OldPos then
                    RootPart.CFrame = getgenv().OldPos * CFrame.new(0, .5, 0)
                    pcall(function() Character:SetPrimaryPartCFrame(getgenv().OldPos * CFrame.new(0, .5, 0)) end)
                end
                if Humanoid then Humanoid:ChangeState("GettingUp") end
                if Character then
                    for _, x in ipairs(Character:GetChildren()) do
                        if x:IsA("BasePart") then
                            x.Velocity, x.RotVelocity = Vector3.new(), Vector3.new()
                        end
                    end
                end
                task.wait()
            until (RootPart and getgenv().OldPos and (RootPart.Position - getgenv().OldPos.p).Magnitude < 25) or not RootPart or not getgenv().OldPos
            workspace.FallenPartsDestroyHeight = getgenv().FPDH
        else
            return Notify("Error Occurred", "Random error", 5)
        end
    end)
    if not success then
        -- swallow/skippable errors when player's character temporary missing/respawning
        -- (avoids spamming notifications). Only notify if it's something serious.
        -- We'll ignore errors since the user's request was to suppress transient errors during respawn.
        -- Uncomment below to debug:
        -- Notify("SkidFling Error", tostring(err), 4)
    end
end


-- ===== GUI =====
local function createGui()
    if not Player then return end
    local existing = Player.PlayerGui:FindFirstChild("SkidFlingGUI")
    if existing then return existing end

    local sg = Instance.new("ScreenGui", Player.PlayerGui)
    sg.Name = "SkidFlingGUI"
    sg.ResetOnSpawn = false

    local frame = Instance.new("Frame", sg)
    frame.Size = UDim2.new(0,220,0,320)
    frame.Position = UDim2.new(0,0,2/5,0)

    local input = Instance.new("TextBox", frame)
    input.Size = UDim2.new(1,-10,0,28)
    input.Position = UDim2.new(0,5,0,34)

    local list = Instance.new("ScrollingFrame", frame)
    list.Size = UDim2.new(1,-10,1,-80)
    list.Position = UDim2.new(0,5,0,70)

    local layout = Instance.new("UIListLayout", list)

    local function refresh()
        for _, c in ipairs(list:GetChildren()) do
            if c:IsA("TextButton") then c:Destroy() end
        end

        for i, name in ipairs(getgenv().Exclusions) do
            local btn = Instance.new("TextButton", list)
            btn.Size = UDim2.new(1,-10,0,26)
            btn.Text = name

            btn.MouseButton1Click:Connect(function()
                table.remove(getgenv().Exclusions, i)
                refresh()
            end)
        end
    end

    input.FocusLost:Connect(function(enter)
        if not enter then return end
        local matches = findPlayersByPartial(input.Text)

        if #matches == 1 then
            table.insert(getgenv().Exclusions, matches[1].Name)
        end

        input.Text = ""
        refresh()
    end)

    refresh()
end

createGui()

-- ===== Toggle =====
UserInputService.InputBegan:Connect(function(i,g)
    if not g and i.KeyCode == Enum.KeyCode.F then
        getgenv().FlingEnabled = not getgenv().FlingEnabled
        Notify("Toggle", tostring(getgenv().FlingEnabled))
    end
end)

-- ===== Main loop =====
while true do
    task.wait(1)
    if not getgenv().FlingEnabled then continue end

    for _, pl in ipairs(Players:GetPlayers()) do
        if pl ~= Player and not table.find(getgenv().Exclusions, pl.Name) then
            SkidFling(pl)
            task.wait(FLING_INTERVAL)
        end
    end
end


