local function createGui()
    if not Player then return end
    local existing = Player:FindFirstChild("PlayerGui") and Player.PlayerGui:FindFirstChild("SkidFlingGUI")
    if existing then return existing end

    local sg = Instance.new("ScreenGui")
    sg.Name = "SkidFlingGUI"
    sg.ResetOnSpawn = false
    sg.Parent = Player:WaitForChild("PlayerGui")

    local frame = Instance.new("Frame")
    frame.Name = "MainFrame"
    frame.Size = UDim2.new(0, 220, 0, 320)
    frame.Position = UDim2.new(0, 0, 2/5, 0) -- left edge, 2/5 down
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    frame.BorderSizePixel = 0
    frame.Parent = sg

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 28)
    title.Position = UDim2.new(0, 0, 0, 0)
    title.Text = "Exclusions"
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.BackgroundTransparency = 1
    title.Parent = frame

    local input = Instance.new("TextBox")
    input.Name = "Input"
    input.Size = UDim2.new(1, -10, 0, 28)
    input.Position = UDim2.new(0, 5, 0, 34)
    input.PlaceholderText = "" -- user requested removing default "textbox"
    input.Text = ""           -- ensure blank
    input.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    input.TextColor3 = Color3.fromRGB(255, 255, 255)
    input.ClearTextOnFocus = false
    input.Parent = frame

    local list = Instance.new("ScrollingFrame")
    list.Name = "List"
    list.Size = UDim2.new(1, -10, 1, -80)
    list.Position = UDim2.new(0, 5, 0, 70)
    list.BackgroundTransparency = 1
    list.ScrollBarThickness = 6
    list.Parent = frame

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 6)
    layout.Parent = list

    local function refresh()
        for _, child in ipairs(list:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        for i, name in ipairs(getgenv().Exclusions) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -10, 0, 26)
            btn.Position = UDim2.new(0, 5, 0, 0)
            btn.Text = name -- display username for readability
            btn.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.Parent = list
            btn.LayoutOrder = i
            btn.MouseButton1Click:Connect(function()
                for idx = #getgenv().Exclusions, 1, -1 do
                    if getgenv().Exclusions[idx] == name then
                        table.remove(getgenv().Exclusions, idx)
                        break
                    end
                end
                saveExclusions(getgenv().Exclusions)
                refresh()
            end)
        end
        list.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 6)
    end

    -- smart add on enter (FocusLost with enter true)
    input.FocusLost:Connect(function(enter)
        if not enter then return end
        local txt = tostring(input.Text or ""):match("^%s*(.-)%s*$") or ""
        if txt == "" then input.Text = "" return end

        local matches = findPlayersByPartial(txt)
        if #matches == 0 then
            Notify("Exclusion Error", "No player found for '" .. txt .. "'", 3)
        elseif #matches > 1 then
            -- check for exact match first
            local exact = nil
            for _, pl in ipairs(matches) do
                if pl.Name:lower() == txt:lower() or (pl.DisplayName and pl.DisplayName:lower() == txt:lower()) then
                    exact = pl
                    break
                end
            end
            if exact then
                if not table.find(getgenv().Exclusions, exact.Name) then
                    table.insert(getgenv().Exclusions, exact.Name)
                    saveExclusions(getgenv().Exclusions)
                    Notify("Exclusion Added", exact.Name, 2)
                else
                    Notify("Exclusion Info", exact.Name .. " already excluded", 2)
                end
            else
                Notify("Exclusion Ambiguous", "Multiple players match '" .. txt .. "'. Type more characters.", 4)
            end
        else
            local pl = matches[1]
            if not table.find(getgenv().Exclusions, pl.Name) then
                table.insert(getgenv().Exclusions, pl.Name)
                saveExclusions(getgenv().Exclusions)
                Notify("Exclusion Added", pl.Name, 2)
            else
                Notify("Exclusion Info", pl.Name .. " already excluded", 2)
            end
        end

        input.Text = ""
        refresh()
    end)

    refresh()
    return sg
end

