-- ===== Phase detection: ReplicatedStorage -> GameValues -> children TextValue & TimerValue =====
local function shouldFlingByPhase()
    local ok, GameValues = pcall(function() return ReplicatedStorage:FindFirstChild("GameValues") end)
    if not ok or not GameValues then return false end
    local TextValue = GameValues:FindFirstChild("TextValue")
    local TimerValue = GameValues:FindFirstChild("TimerValue")
    if not TextValue or not TimerValue then return false end
    local phase = TextValue.Value
    local timerNum = tonumber(TimerValue.Value) or 0
    if phase == "SURVIVE" then
        return true
    elseif phase == "PREPARE" and timerNum <= 13 then
        return true
    else
        return false
    end
end

-- ===== Main manager: scan for human players and spawn persistent loopfling coroutines =====
coroutine.wrap(function()
    while true do
        task.wait(0.25)

        if not getgenv().FlingEnabled then
            task.wait(0.5)
            continue
        end

        if not shouldFlingByPhase() then
            task.wait(1)
            continue
        end

        -- Build targets: Humans team only, not excluded, not already active
        local queuedTargets = {}
        for _, pl in ipairs(Players:GetPlayers()) do
            if pl ~= Player and pl.Team and pl.Team.Name == "Humans" and pl.Character and not table.find(getgenv().Exclusions, pl.Name) then
                if not ActiveFlingTargets[pl.UserId] then
                    table.insert(queuedTargets, pl)
                end
            end
        end

        -- If none, loop again (this satisfies "continue flinging until all Humans except exclusions are off the team")
        if #queuedTargets == 0 then
            task.wait(0.5)
            continue
        end

        -- Iterate queued targets; for each we spawn a persistent coroutine that repeatedly calls SkidFling(target)
        for _, targetPlayer in ipairs(queuedTargets) do
            if not getgenv().FlingEnabled then break end
            if not targetPlayer or targetPlayer.Parent ~= Players then
                -- skip invalids
            else
                -- mark active
                ActiveFlingTargets[targetPlayer.UserId] = true

                -- Start persistent per-target coroutine (runs until the target leaves Humans or is removed or is excluded)
                coroutine.wrap(function(tp)
                    -- we intentionally loop and call SkidFling(tp) repeatedly with small intervals so it persists.
                    while true do
                        -- break conditions:
                        if not getgenv().FlingEnabled then break end
                        if not tp or tp.Parent ~= Players then break end
                        if table.find(getgenv().Exclusions, tp.Name) then break end
                        if not tp.Team or tp.Team.Name ~= "Humans" then break end
                        if not tp.Character then
                            -- wait for character to exist (handles respawn)
                            task.wait(0.5)
                            continue
                        end
                        -- call protected
                        pcall(function() SkidFling(tp) end)
                        -- small wait to avoid tight loop inside this target's coroutine
                        -- The per-target loopfling should persist indefinitely (until above breaks).
                        task.wait(0.2)
                    end
                    -- cleanup on exit
                    ActiveFlingTargets[tp.UserId] = nil
                end)(targetPlayer)
            end

            -- Wait FLING_INTERVAL between starting commands for new players (stacking behavior)
            local waited = 0
            while waited < FLING_INTERVAL do
                task.wait(0.1)
                waited = waited + 0.1
                if not getgenv().FlingEnabled then break end
            end
            if not getgenv().FlingEnabled then break end
        end
    end
end)()

-- ===== Player leaving: cleanup exclusions and active target map =====
Players.PlayerRemoving:Connect(function(removed)
    for idx = #getgenv().Exclusions, 1, -1 do
        if getgenv().Exclusions[idx] == removed.Name then
            table.remove(getgenv().Exclusions, idx)
        end
    end
    saveExclusions(getgenv().Exclusions)
    ActiveFlingTargets[removed.UserId] = nil
end)

